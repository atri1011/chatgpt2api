{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "web_dist",
  "functions": {
    "api.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/v1/(.*)",
      "destination": "/api"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ]
}